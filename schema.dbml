}

Table wishlists {
  id int [pk, increment]
  customer_id int [not null]
  name varchar(140) [not null]
  is_public boolean [not null, default: false]
  created_at timestamp [not null, default: `now()`]
}

Table wishlist_items {
  wishlist_id int [pk]

}

Table suppliers {
  id int [pk, increment]
  tenant_id int [not null]
  default_currency_id int
  name varchar(160) [not null]
  tax_identifier varchar(80)
  status varchar(40) [default: 'active']
}

Table supplier_contacts {
  id int [pk, increment]
  supplier_id int [not null]
  name varchar(140) [not null]
  email varchar(255)
  phone varchar(40)
  is_primary boolean [not null, default: false]
}

Table categories [service_usage: 5, controller_usage: 5] {
  id int [pk, increment]
  tenant_id int [not null]
  parent_category_id int
  name varchar(140) [not null]
  slug varchar(140) [not null]
  sort_order int [not null, default: 0]
}

Table product_types {
  id int [pk, increment]
  tenant_id int [not null]
  name varchar(120) [not null]
  handle varchar(100) [not null]
  default_tax_category_id int
}

Table products [service_usage: 17, controller_usage: 12, color: '#bf8700'] {
  id int [pk, increment]
  tenant_id int [not null]
  brand_id int
  product_type_id int
  default_category_id int
  title varchar(255) [not null]
  status product_status [not null, default: 'draft']
  created_at timestamp [not null, default: `now()`]
  Note: 'Catalog hub connected to variants, media, reviews, inventory, pricing, orders, and marketing.'
}

Table product_variants [service_usage: 12, controller_usage: 7] {
  id int [pk, increment]
  product_id int [not null]
  sku varchar(120) [not null, unique]
  barcode varchar(120)

}

Table inventory_locations [service_usage: 9, controller_usage: 5] {
  id int [pk, increment]
  tenant_id int [not null]
  country_id int
  name varchar(140) [not null]
  location_type varchar(60) [not null]
  is_active boolean [not null, default: true]
}

Table inventory_items [service_usage: 16, controller_usage: 8, color: '#0598bc'] {
  id int [pk, increment]
  tenant_id int [not null]
  variant_id int [not null]
  location_id int [not null]

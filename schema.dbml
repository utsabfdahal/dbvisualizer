}

Table purchase_order_items {
  id int [pk, increment]
  purchase_order_id int [not null]
  variant_id int [not null]
  destination_location_id int [not null]
  quantity int [not null]
  unit_cost_cents int [not null]
}

Table supplier_invoices {
  id int [pk, increment]

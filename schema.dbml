  captured_at timestamp [not null, default: `now()`]
}

// -----------------------------------------------------------------------------
// Checkout, orders, billing, payments, and subscriptions
// -----------------------------------------------------------------------------

Table carts {
  id int [pk, increment]
  tenant_id int [not null]
  customer_id int
  sales_channel_id int [not null]
  status cart_status [not null, default: 'open']
  currency_id int [not null]
  created_at timestamp [not null, default: `now()`]
}

Table cart_items {
  id int [pk, increment]
  cart_id int [not null]
  variant_id int [not null]
  quantity int [not null, default: 1]
  unit_price_cents int [not null]
  added_at timestamp [not null, default: `now()`]
}

Table checkout_sessions {
  id int [pk, increment]
  cart_id int [not null, unique]
  customer_id int
  billing_address_id int
  shipping_address_id int
  expires_at timestamp [not null]
  completed_at timestamp
}

Table orders [service_usage: 19, controller_usage: 13, color: '#d4641c'] {
  id int [pk, increment]
  tenant_id int [not null]
  customer_id int [not null]
  store_id int
  sales_channel_id int [not null]
  currency_id int [not null]
  status order_status [not null, default: 'pending']
  total_cents int [not null, default: 0]
  created_at timestamp [not null, default: `now()`]
  Note: 'Operational hub connecting checkout, fulfillment, invoicing, payments, loyalty, support, and analytics.'
}

Table order_items {
  id int [pk, increment]
  order_id int [not null]
  variant_id int [not null]
  product_id int [not null]
  quantity int [not null]
  unit_price_cents int [not null]
  tax_rate_id int
}

Table order_adjustments {
  id int [pk, increment]
  order_id int [not null]
  coupon_id int
  description varchar(160) [not null]
  amount_cents int [not null]
  created_at timestamp [not null, default: `now()`]
}

Table order_events {
  id int [pk, increment]
  order_id int [not null]
  actor_user_id int
  old_status order_status
  new_status order_status [not null]
  message text
  created_at timestamp [not null, default: `now()`]
}

Table invoices {
  id int [pk, increment]
  order_id int
  subscription_id int
  customer_id int [not null]
  currency_id int [not null]
  status invoice_status [not null, default: 'draft']
  total_cents int [not null, default: 0]
  due_at timestamp
}

Table invoice_lines {
  id int [pk, increment]
  invoice_id int [not null]
  order_item_id int
  subscription_item_id int
  description varchar(255) [not null]
  quantity decimal(12,4) [not null, default: 1]
  amount_cents int [not null]
}

Table payment_methods {
  id int [pk, increment]
  tenant_id int [not null]
  customer_id int [not null]
  provider varchar(60) [not null]
  brand varchar(60)
  last4 char(4)
  expires_at date
}

Table payment_intents {
  id int [pk, increment]
  tenant_id int [not null]
  customer_id int [not null]
  order_id int
  invoice_id int
  payment_method_id int
  amount_cents int [not null]
  status payment_status [not null, default: 'requires_action']
}

Table payments [service_usage: 12, controller_usage: 7] {
  id int [pk, increment]
  payment_intent_id int [not null]
  order_id int
  invoice_id int
  provider_reference varchar(255)
  amount_cents int [not null]
  status payment_status [not null, default: 'captured']
  captured_at timestamp
}

Table payment_refunds {
  id int [pk, increment]
  payment_id int [not null]
  return_id int
  amount_cents int [not null]
  reason varchar(160)

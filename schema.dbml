  code varchar(80) [not null]
  value_type varchar(40) [not null]
}

Table product_attribute_values {
  id int [pk, increment]
  product_id int [not null]
  attribute_id int [not null]
  value_text text
  value_number decimal(14,4)
}

Table product_variant_attribute_values {
  variant_id int [pk]

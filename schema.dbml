// OmniPlatform Showcase Schema
// Purpose: stress-test DBVisualizer with 150+ interconnected tables, enums, table groups,
// centrality badges, self-references, many-to-many joins, and cross-domain relations.

Project omniplatform_showcase {
  database_type: 'PostgreSQL'
  Note: 'Multi-tenant commerce, CRM, logistics, analytics, automation, and AI platform demo schema.'
}

Enum tenant_status { trial active paused suspended closed }
Enum user_status { invited active locked disabled deleted }
Enum member_role { owner admin manager contributor viewer }
Enum audit_action { create update delete login export import approve reject }
Enum file_visibility { private tenant_public public }
Enum entity_kind { tenant user customer product order shipment ticket campaign report automation ai_run }
Enum channel_kind { web mobile pos marketplace social api }
Enum product_status { draft active archived discontinued }
Enum stock_movement_type { receive reserve release adjust transfer ship return damage cycle_count }
Enum customer_status { lead prospect active dormant blocked }
Enum address_type { billing shipping pickup legal }
Enum cart_status { open converted abandoned expired }
Enum order_status { draft pending confirmed paid packed shipped delivered cancelled refunded }
Enum invoice_status { draft open paid void overdue }
Enum payment_status { requires_action authorized captured failed refunded disputed cancelled }
Enum shipment_status { pending label_created in_transit out_for_delivery delivered exception cancelled returned }
Enum return_status { requested approved received rejected refunded closed }
Enum campaign_status { draft scheduled running paused completed archived }
Enum notification_status { queued sent failed read archived }
Enum ticket_status { new open pending_customer pending_internal solved closed }
Enum sync_status { queued running succeeded failed cancelled }
Enum automation_status { draft enabled disabled archived }
Enum ai_run_status { queued running completed failed cancelled }

// -----------------------------------------------------------------------------
// Identity & tenancy
// -----------------------------------------------------------------------------

Table tenants [service_usage: 18, controller_usage: 12, color: '#2f6feb'] {
  id int [pk, increment]
  name varchar(160) [not null]
  slug varchar(80) [not null, unique]
  status tenant_status [not null, default: 'trial']
  billing_email varchar(255)
  created_at timestamp [not null, default: `now()`]
  Note: 'Root account for every domain object in the platform.'
}

Table tenant_domains {
  id int [pk, increment]
  tenant_id int [not null]
  domain varchar(255) [not null, unique]
  is_primary boolean [not null, default: false]
  verified_at timestamp
  created_at timestamp [not null, default: `now()`]
}

Table tenant_settings {
  id int [pk, increment]
  tenant_id int [not null]
  setting_key varchar(120) [not null]
  setting_value text
  is_secret boolean [not null, default: false]
  updated_at timestamp [not null, default: `now()`]
}

Table tenant_feature_entitlements {
  id int [pk, increment]
  tenant_id int [not null]
  feature_key varchar(120) [not null]
  limit_value int
  enabled boolean [not null, default: true]
  expires_at timestamp
}

Table users [service_usage: 16, controller_usage: 14, color: '#8957e5'] {
  id int [pk, increment]
  tenant_id int [not null]
  email varchar(255) [not null]
  display_name varchar(140) [not null]
  status user_status [not null, default: 'invited']
  last_login_at timestamp
  created_at timestamp [not null, default: `now()`]
  Note: 'Human or service actor used across admin, storefront, and operations workflows.'
}

Table user_profiles {
  id int [pk, increment]
  user_id int [not null, unique]
  avatar_file_id int
  locale varchar(16) [default: 'en-US']
  timezone varchar(80)
  phone varchar(40)
}

Table user_identities {
  id int [pk, increment]
  user_id int [not null]
  provider varchar(60) [not null]
  provider_subject varchar(255) [not null]
  mfa_enabled boolean [not null, default: false]
  linked_at timestamp [not null, default: `now()`]
}

Table user_sessions {
  id int [pk, increment]
  user_id int [not null]
  token_hash varchar(255) [not null, unique]
  ip_address varchar(64)
  user_agent text
  expires_at timestamp [not null]
}

Table api_keys {
  id int [pk, increment]
  tenant_id int [not null]
  owner_user_id int
  key_prefix varchar(32) [not null, unique]
  name varchar(120) [not null]
  revoked_at timestamp
  created_at timestamp [not null, default: `now()`]
}

Table roles {
  id int [pk, increment]
  tenant_id int [not null]
  name varchar(80) [not null]
  description text
  is_system boolean [not null, default: false]
  created_at timestamp [not null, default: `now()`]
}

Table permissions {
  id int [pk, increment]
  code varchar(120) [not null, unique]
  resource varchar(80) [not null]
  action varchar(60) [not null]
  description text
}

Table role_permissions {
  role_id int [pk]
  permission_id int [pk]
  granted_by_user_id int
  granted_at timestamp [not null, default: `now()`]
}

Table user_roles {
  user_id int [pk]
  role_id int [pk]
  assigned_by_user_id int
  assigned_at timestamp [not null, default: `now()`]
}

Table teams [service_usage: 5, controller_usage: 4] {
  id int [pk, increment]
  tenant_id int [not null]
  parent_team_id int
  name varchar(120) [not null]
  handle varchar(80)
  created_at timestamp [not null, default: `now()`]
}

Table team_members {
  team_id int [pk]
  user_id int [pk]
  role member_role [not null, default: 'contributor']
  joined_at timestamp [not null, default: `now()`]
}

Table invitations {
  id int [pk, increment]
  tenant_id int [not null]
  invited_by_user_id int [not null]
  email varchar(255) [not null]
  role_id int
  accepted_user_id int
  expires_at timestamp [not null]
}

Table audit_logs [service_usage: 8, controller_usage: 2] {
  id int [pk, increment]
  tenant_id int [not null]
  actor_user_id int
  action audit_action [not null]
  entity_kind entity_kind [not null]
  entity_id int [not null]
  created_at timestamp [not null, default: `now()`]
}

Table webhook_endpoints {
  id int [pk, increment]
  tenant_id int [not null]
  created_by_user_id int
  url varchar(500) [not null]
  secret_hint varchar(80)
  is_active boolean [not null, default: true]
}

Table webhook_deliveries {
  id int [pk, increment]
  endpoint_id int [not null]
  event_id int
  status_code int
  attempt_count int [not null, default: 0]
  delivered_at timestamp
}

Table files [service_usage: 7, controller_usage: 6] {
  id int [pk, increment]
  tenant_id int [not null]
  uploaded_by_user_id int
  storage_key varchar(500) [not null, unique]
  mime_type varchar(120)
  visibility file_visibility [not null, default: 'private']
  created_at timestamp [not null, default: `now()`]
}

Table file_versions {
  id int [pk, increment]
  file_id int [not null]
  version_no int [not null]
  size_bytes int [not null]
  checksum varchar(128)
  created_at timestamp [not null, default: `now()`]
}

Table tags {
  id int [pk, increment]
  tenant_id int [not null]
  name varchar(80) [not null]
  color varchar(16)
  created_by_user_id int
}

Table entity_tags {
  tag_id int [pk]
  entity_kind entity_kind [pk]
  entity_id int [pk]
  tagged_by_user_id int
  tagged_at timestamp [not null, default: `now()`]
}

Table comments {
  id int [pk, increment]
  tenant_id int [not null]
  parent_comment_id int
  author_user_id int [not null]
  entity_kind entity_kind [not null]
  entity_id int [not null]
  body text [not null]
  created_at timestamp [not null, default: `now()`]
}

Table comment_mentions {
  comment_id int [pk]
  mentioned_user_id int [pk]
  notified_at timestamp
}

// -----------------------------------------------------------------------------
// Commerce setup, catalog, pricing, and inventory
// -----------------------------------------------------------------------------

Table currencies {
  id int [pk, increment]
  code char(3) [not null, unique]
  name varchar(80) [not null]
  symbol varchar(12)
  minor_unit int [not null, default: 2]
}

Table countries {
  id int [pk, increment]
  iso_code char(2) [not null, unique]
  name varchar(120) [not null]
  default_currency_id int
  phone_prefix varchar(12)
}

Table regions {
  id int [pk, increment]
  country_id int [not null]
  code varchar(32) [not null]
  name varchar(120) [not null]
  tax_zone varchar(80)
}

Table tax_categories {
  id int [pk, increment]
  tenant_id int [not null]
  name varchar(120) [not null]
  code varchar(80) [not null]
  is_default boolean [not null, default: false]
}

Table tax_rates {
  id int [pk, increment]
  tenant_id int [not null]
  tax_category_id int [not null]
  country_id int [not null]
  region_id int
  rate decimal(6,4) [not null]
  starts_at timestamp [not null]
}

Table sales_channels [service_usage: 7, controller_usage: 6] {
  id int [pk, increment]
  tenant_id int [not null]
  name varchar(120) [not null]
  kind channel_kind [not null]
  default_currency_id int
  is_active boolean [not null, default: true]
}

Table stores [service_usage: 8, controller_usage: 7, color: '#1f883d'] {
  id int [pk, increment]
  tenant_id int [not null]
  default_channel_id int
  name varchar(140) [not null]
  url varchar(255)
  timezone varchar(80)
  created_at timestamp [not null, default: `now()`]
}

Table store_staff {
  store_id int [pk]
  user_id int [pk]
  role member_role [not null, default: 'contributor']
  assigned_at timestamp [not null, default: `now()`]
}

Table brands {
  id int [pk, increment]
  tenant_id int [not null]
  logo_file_id int
  name varchar(140) [not null]
  slug varchar(120) [not null]
